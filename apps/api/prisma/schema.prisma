generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String
  body        String        @default("")
  category    String?
  author      String?
  color       String?
  emoji       String?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  excerpt     String
  description String        @default("")
  category    String?
  priceCents  Int           @default(0)
  color       String?
  emoji       String?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model KajianEvent {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String
  speaker     String?
  location    String?
  eventType   String?
  startsAt    DateTime?
  color       String?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Course {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String
  description String        @default("")
  category    String?
  level       String?
  format      String?
  priceCents  Int           @default(0)
  color       String?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
