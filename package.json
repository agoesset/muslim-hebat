{
  "name": "muslim-hebat",
  "version": "1.0.0",
  "private": true,
  "description": "Production web app for Muslim Hebat.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @muslim-hebat/web",
    "dev:web": "npm run dev -w @muslim-hebat/web",
    "dev:api": "npm run dev -w @muslim-hebat/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w @muslim-hebat/web",
    "build:api": "npm run build -w @muslim-hebat/api",
    "preview": "npm run preview -w @muslim-hebat/web",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "npm run prisma:generate -w @muslim-hebat/api",
    "db:migrate": "npm run prisma:migrate -w @muslim-hebat/api",
    "db:seed": "npm run seed -w @muslim-hebat/api",
    "heroku-postbuild": "npm run db:generate && npm run build -w @muslim-hebat/web && npm run build -w @muslim-hebat/api && rm -rf apps/api/dist/src/public && cp -r apps/web/dist apps/api/dist/src/public",
    "start": "npm run start -w @muslim-hebat/api"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  }
}
